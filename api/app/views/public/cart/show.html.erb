<% content_for :title, "Carrinho" %>

<div class="max-w-4xl mx-auto px-6 py-12">
  <div style="font-size:10px;letter-spacing:0.16em;text-transform:uppercase;font-family:var(--font-mono);color:var(--brand-muted);margin-bottom:16px;">Seu pedido</div>
  <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,6vw,3.5rem);font-weight:300;letter-spacing:-0.02em;margin-bottom:48px;">Carrinho</h1>

  <div id="cart-page-empty" style="text-align:center;padding:64px 0;">
    <p style="font-size:15px;color:var(--brand-muted);margin-bottom:24px;">Seu carrinho está vazio.</p>
    <%= link_to "Ver catálogo", root_path, style: "display:inline-block;padding:12px 28px;border:1px solid var(--brand-foreground);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;font-family:var(--font-mono);color:var(--brand-foreground);text-decoration:none;" %>
  </div>

  <div id="cart-page-content" style="display:none;">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <%# Items list %>
      <div class="md:col-span-2" id="cart-page-items"></div>

      <%# Resumo + CTA %>
      <div>
        <div style="border:1px solid var(--brand-border);padding:24px;position:sticky;top:80px;">
          <div style="font-size:10px;letter-spacing:0.12em;text-transform:uppercase;font-family:var(--font-mono);color:var(--brand-muted);margin-bottom:16px;">Resumo</div>
          <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:13px;">
            <span>Peças</span><span id="summary-qty" style="font-family:var(--font-mono);">0</span>
          </div>
          <div style="display:flex;justify-content:space-between;margin-bottom:20px;font-size:15px;font-weight:600;border-top:1px solid var(--brand-border);padding-top:14px;margin-top:14px;">
            <span>Total</span><span id="summary-total" style="font-family:var(--font-mono);color:var(--brand-primary);">—</span>
          </div>
          <a id="whatsapp-order-btn" href="#" target="_blank" rel="noopener"
             style="display:block;padding:16px;text-align:center;background:var(--brand-primary);color:#fff;text-decoration:none;
                    font-size:11px;letter-spacing:0.12em;text-transform:uppercase;font-family:var(--font-mono);margin-bottom:10px;">
            Fazer pedido via WhatsApp
          </a>
          <button onclick="if(confirm('Limpar carrinho?')){Cart.clear();renderCartPage();}"
                  style="width:100%;padding:10px;background:none;border:1px solid var(--brand-border);cursor:pointer;
                         font-size:10px;letter-spacing:0.1em;text-transform:uppercase;font-family:var(--font-mono);color:#888;">
            Limpar carrinho
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function renderCartPage() {
  var items   = Cart.getItems();
  var empty   = document.getElementById("cart-page-empty");
  var content = document.getElementById("cart-page-content");
  if (!items.length) {
    empty.style.display   = "block";
    content.style.display = "none";
    return;
  }
  empty.style.display   = "none";
  content.style.display = "block";

  document.getElementById("summary-qty").textContent   = Cart.totalQty();
  document.getElementById("summary-total").textContent = Cart.brl(Cart.totalPrice());

  var phone = document.body.dataset.whatsappPhone || "";
  var msg   = Cart.buildWhatsAppMessage();
  document.getElementById("whatsapp-order-btn").href =
    "https://wa.me/" + phone + "?text=" + encodeURIComponent(msg);

  var list = document.getElementById("cart-page-items");
  list.innerHTML = items.map(function(item, idx) {
    return '<div style="display:flex;gap:16px;padding:20px 0;border-bottom:1px solid var(--brand-border);">' +
      '<div style="width:80px;height:105px;flex-shrink:0;background:var(--brand-surface);overflow:hidden;">' +
        (item.imageUrl ? '<img src="' + item.imageUrl + '" alt="' + item.name + '" style="width:100%;height:100%;object-fit:cover;">' : '') +
      '</div>' +
      '<div style="flex:1;">' +
        '<div style="font-size:15px;font-weight:500;margin-bottom:4px;">' + item.name + '</div>' +
        '<div style="font-size:11px;color:#888;font-family:var(--font-mono);margin-bottom:12px;">' +
          [item.color, item.size].filter(Boolean).join(' · ') + '</div>' +
        '<div style="display:flex;align-items:center;gap:8px;">' +
          '<button onclick="Cart.updateQty(' + idx + ',' + (item.qty-1) + ');renderCartPage()" style="width:28px;height:28px;border:1px solid var(--brand-border);background:#fff;cursor:pointer;">−</button>' +
          '<span style="font-family:var(--font-mono);font-size:14px;width:28px;text-align:center;">' + item.qty + '</span>' +
          '<button onclick="Cart.updateQty(' + idx + ',' + (item.qty+1) + ');renderCartPage()" style="width:28px;height:28px;border:1px solid var(--brand-border);background:#fff;cursor:pointer;">+</button>' +
          '<button onclick="Cart.removeItem(' + idx + ');renderCartPage()" style="margin-left:8px;font-size:11px;color:#bbb;background:none;border:0;cursor:pointer;font-family:var(--font-mono);">remover</button>' +
        '</div>' +
      '</div>' +
      '<div style="text-align:right;">' +
        '<div style="font-family:var(--font-mono);font-size:15px;font-weight:700;">' + Cart.brl(item.price * item.qty) + '</div>' +
        '<div style="font-size:11px;color:#aaa;font-family:var(--font-mono);margin-top:4px;">' + Cart.brl(item.price) + '/un.</div>' +
      '</div>' +
    '</div>';
  }).join('');
}
document.addEventListener("DOMContentLoaded", renderCartPage);
</script>

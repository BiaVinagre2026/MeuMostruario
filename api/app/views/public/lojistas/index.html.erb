<% content_for :title, "Pedido Atacado" %>

<script>var BRAND_NAME = "<%= j current_tenant&.name.to_s %>";</script>

<%# ── Barra de resumo sticky ── %>
<div id="order-bar"
     style="position:sticky;top:64px;z-index:40;background:#fff;border-bottom:1px solid var(--brand-border);
            padding:12px 24px;display:flex;justify-content:space-between;align-items:center;">
  <div style="font-family:var(--font-mono);font-size:12px;">
    <span style="color:var(--brand-muted);text-transform:uppercase;letter-spacing:0.1em;">Pedido · </span>
    <span id="grand-qty" style="font-weight:700;">0</span>
    <span style="color:var(--brand-muted);"> peças · </span>
    <span id="grand-value" style="font-weight:700;color:var(--brand-primary);">R$ 0,00</span>
  </div>
  <a id="whatsapp-order-btn" href="#" target="_blank" rel="noopener"
     style="display:none;background:var(--brand-primary);color:#fff;padding:10px 24px;
            text-decoration:none;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;font-family:var(--font-mono);">
    Enviar Pedido via WhatsApp
  </a>
</div>

<div class="max-w-7xl mx-auto px-6 py-10">

  <%# Header -%>
  <div style="margin-bottom:40px;">
    <div style="font-size:10px;letter-spacing:0.16em;text-transform:uppercase;font-family:var(--font-mono);color:var(--brand-muted);margin-bottom:8px;">Catálogo B2B</div>
    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,3.5rem);font-weight:300;letter-spacing:-0.03em;line-height:1.1;margin-bottom:12px;">
      Pedido de Atacado
    </h1>
    <p style="font-size:14px;color:var(--brand-muted);max-width:540px;">
      Preencha as quantidades desejadas por cor e tamanho. Ao concluir, clique em <strong>Enviar Pedido via WhatsApp</strong>.
    </p>
  </div>

  <%# Filtro por coleção -%>
  <% if @collections.any? %>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:32px;" id="col-filters">
      <button onclick="filterCol('all')" data-col="all"
              style="padding:6px 16px;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;font-family:var(--font-mono);
                     border:1px solid var(--brand-foreground);background:var(--brand-foreground);color:#fff;cursor:pointer;">
        Todas
      </button>
      <% @collections.each do |col| %>
        <button onclick="filterCol('<%= col.slug %>')" data-col="<%= col.slug %>"
                style="padding:6px 16px;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;font-family:var(--font-mono);
                       border:1px solid var(--brand-border);background:#fff;color:var(--brand-foreground);cursor:pointer;">
          <%= col.name %>
        </button>
      <% end %>
    </div>
  <% end %>

  <%# Grades por produto -%>
  <div style="display:flex;flex-direction:column;gap:2px;" id="products-list">

    <% @products.each do |p| %>
      <%
        colors_data = p.variants.sort_by(&:position)
                       .group_by(&:color)
                       .filter_map do |color, variants|
                         next if color.blank?
                         { name: color, hex: variants.first.color_hex, image_url: variants.first.image_url, sizes: variants.map(&:size) }
                       end
        all_sizes = p.variants.map(&:size).uniq.compact
        cover     = cover_url(p)
      %>
      <div class="product-grade"
           data-product-id="<%= p.id %>"
           data-product-name="<%= j p.name %>"
           data-sku="<%= p.sku %>"
           data-price="<%= p.price_wholesale.to_f %>"
           data-col="<%= p.collection&.slug %>"
           style="border:1px solid var(--brand-border);background:#fff;">

        <%# Toggle header -%>
        <button onclick="toggleGrade(this)"
                style="width:100%;display:flex;align-items:center;gap:16px;padding:16px 20px;background:none;border:0;cursor:pointer;text-align:left;">
          <% if cover %>
            <img src="<%= cover %>" alt="<%= p.name %>"
                 style="width:64px;height:80px;object-fit:cover;flex-shrink:0;background:var(--brand-surface);" loading="lazy" />
          <% else %>
            <div style="width:64px;height:80px;background:var(--brand-surface);flex-shrink:0;"></div>
          <% end %>
          <div style="flex:1;min-width:0;">
            <div style="font-size:15px;font-weight:500;margin-bottom:2px;"><%= p.name %></div>
            <div style="font-family:var(--font-mono);font-size:11px;color:var(--brand-muted);">SKU <%= p.sku %></div>
          </div>
          <div style="text-align:right;flex-shrink:0;margin-right:8px;">
            <div style="font-family:var(--font-mono);font-size:14px;font-weight:700;color:var(--brand-primary);"><%= format_brl(p.price_wholesale) %>/un</div>
            <div class="grade-subtotal" style="font-family:var(--font-mono);font-size:11px;color:var(--brand-muted);margin-top:2px;"></div>
          </div>
          <span class="toggle-icon" style="font-size:18px;color:var(--brand-muted);flex-shrink:0;">+</span>
        </button>

        <%# Grade colapsável -%>
        <div class="grade-body" style="display:none;padding:0 20px 20px;">
          <% if colors_data.any? && all_sizes.any? %>
            <div style="overflow-x:auto;">
              <table style="width:100%;border-collapse:collapse;font-size:13px;">
                <thead>
                  <tr>
                    <th style="text-align:left;padding:8px 10px 8px 0;font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--brand-muted);border-bottom:1px solid var(--brand-border);white-space:nowrap;">Cor / Tam.</th>
                    <% all_sizes.each do |sz| %>
                      <th style="text-align:center;padding:8px;font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--brand-muted);border-bottom:1px solid var(--brand-border);min-width:52px;"><%= sz %></th>
                    <% end %>
                    <th style="text-align:right;padding:8px 0 8px 10px;font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--brand-muted);border-bottom:1px solid var(--brand-border);">Subtotal</th>
                  </tr>
                </thead>
                <tbody>
                  <% colors_data.each do |cd| %>
                    <tr data-color="<%= cd[:name] %>" style="border-bottom:1px solid var(--brand-border);">
                      <td style="padding:10px 10px 10px 0;white-space:nowrap;">
                        <div style="display:flex;align-items:center;gap:8px;">
                          <span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:<%= cd[:hex] || '#ccc' %>;border:1px solid rgba(0,0,0,0.1);flex-shrink:0;"></span>
                          <span style="font-size:13px;"><%= cd[:name] %></span>
                        </div>
                      </td>
                      <% all_sizes.each do |sz| %>
                        <% has_size = cd[:sizes].include?(sz) %>
                        <td style="text-align:center;padding:6px 8px;">
                          <% if has_size %>
                            <input type="number" min="0" value="0"
                                   data-color="<%= cd[:name] %>"
                                   data-size="<%= sz %>"
                                   oninput="gradeChange(this)"
                                   style="width:48px;text-align:center;padding:6px 4px;border:1px solid var(--brand-border);font-family:var(--font-mono);font-size:13px;-moz-appearance:textfield;" />
                          <% else %>
                            <span style="color:var(--brand-border);font-size:12px;">—</span>
                          <% end %>
                        </td>
                      <% end %>
                      <td style="text-align:right;padding:10px 0 10px 10px;font-family:var(--font-mono);font-size:12px;white-space:nowrap;">
                        <span class="row-total" style="color:var(--brand-muted);">0 un.</span>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
                <tfoot>
                  <tr>
                    <td colspan="<%= all_sizes.size + 2 %>"
                        style="padding:10px 0 0;font-family:var(--font-mono);font-size:12px;text-align:right;color:var(--brand-muted);">
                      Total desta peça:
                      <strong class="product-total-qty" style="color:var(--brand-foreground);">0</strong> un. ·
                      <strong class="product-total-value" style="color:var(--brand-primary);">R$ 0,00</strong>
                    </td>
                  </tr>
                </tfoot>
              </table>
            </div>
          <% end %>
        </div>

      </div>
    <% end %>

  </div>

</div>

<script>
function toggleGrade(btn) {
  var body = btn.closest('.product-grade').querySelector('.grade-body');
  var icon = btn.querySelector('.toggle-icon');
  var open = body.style.display !== 'none';
  body.style.display = open ? 'none' : 'block';
  icon.textContent   = open ? '+' : '−';
}

function gradeChange(input) {
  var val = parseInt(input.value) || 0;
  if (val < 0) { input.value = 0; val = 0; }
  input.value = val;

  var grade = input.closest('.product-grade');
  var row   = input.closest('tr');

  // Row total
  var rowQty = Array.from(row.querySelectorAll('input[type=number]')).reduce(function(s,i){ return s + (parseInt(i.value)||0); }, 0);
  row.querySelector('.row-total').textContent = rowQty + ' un.';

  // Product totals
  var price    = parseFloat(grade.dataset.price);
  var allQty   = Array.from(grade.querySelectorAll('input[type=number]')).reduce(function(s,i){ return s + (parseInt(i.value)||0); }, 0);
  var allValue = allQty * price;
  grade.querySelector('.product-total-qty').textContent   = allQty;
  grade.querySelector('.product-total-value').textContent = brl(allValue);
  grade.querySelector('.grade-subtotal').textContent      = allQty > 0 ? allQty + ' un. · ' + brl(allValue) : '';

  updateGrandTotal();
}

function updateGrandTotal() {
  var grandQty = 0, grandVal = 0;
  document.querySelectorAll('.product-grade').forEach(function(g) {
    var price = parseFloat(g.dataset.price);
    var qty   = Array.from(g.querySelectorAll('input[type=number]')).reduce(function(s,i){ return s + (parseInt(i.value)||0); }, 0);
    grandQty += qty;
    grandVal += qty * price;
  });
  document.getElementById('grand-qty').textContent   = grandQty;
  document.getElementById('grand-value').textContent = brl(grandVal);
  buildWhatsApp(grandQty, grandVal);
}

function buildOrderItems() {
  var items = [];
  document.querySelectorAll('.product-grade').forEach(function(g) {
    var productId   = parseInt(g.dataset.productId);
    var productName = g.dataset.productName;
    var sku         = g.dataset.sku;
    var price       = parseFloat(g.dataset.price);

    g.querySelectorAll('tr[data-color]').forEach(function(row) {
      var color = row.dataset.color;
      row.querySelectorAll('input[type=number]').forEach(function(inp) {
        var q = parseInt(inp.value) || 0;
        if (q > 0) {
          items.push({
            product_id:   productId,
            product_name: productName,
            product_sku:  sku,
            color:        color,
            size:         inp.dataset.size,
            qty:          q,
            unit_price:   price
          });
        }
      });
    });
  });
  return items;
}

function buildWhatsAppText(grandQty, grandVal) {
  var lines = ['*Pedido de Atacado — ' + BRAND_NAME + '*', ''];
  document.querySelectorAll('.product-grade').forEach(function(g) {
    var name  = g.dataset.productName;
    var sku   = g.dataset.sku;
    var price = parseFloat(g.dataset.price);
    var productLines = [];

    g.querySelectorAll('tr[data-color]').forEach(function(row) {
      var color = row.dataset.color;
      var sizeItems = [];
      row.querySelectorAll('input[type=number]').forEach(function(inp) {
        var q = parseInt(inp.value) || 0;
        if (q > 0) sizeItems.push(inp.dataset.size + '(' + q + ')');
      });
      if (sizeItems.length) productLines.push('  ' + color + ': ' + sizeItems.join(', '));
    });

    if (productLines.length) {
      var pQty = Array.from(g.querySelectorAll('input[type=number]')).reduce(function(s,i){ return s+(parseInt(i.value)||0);}, 0);
      lines.push('*' + name + '* (SKU: ' + sku + ') — ' + brl(price) + '/un');
      lines = lines.concat(productLines);
      lines.push('  Subtotal: ' + pQty + ' un. · ' + brl(pQty * price));
      lines.push('');
    }
  });
  lines.push('─────────────────');
  lines.push('*TOTAL: ' + grandQty + ' peças · ' + brl(grandVal) + '*');
  return lines.join('\n');
}

function buildWhatsApp(grandQty, grandVal) {
  var btn = document.getElementById('whatsapp-order-btn');
  if (grandQty === 0) { btn.style.display = 'none'; return; }

  var phone   = document.body.dataset.whatsappPhone || '';
  var waText  = buildWhatsAppText(grandQty, grandVal);
  var waUrl   = 'https://wa.me/' + phone + '?text=' + encodeURIComponent(waText);

  btn.onclick = function(e) {
    e.preventDefault();
    var items  = buildOrderItems();
    var csrfToken = (document.querySelector('meta[name="csrf-token"]') || {}).content || '';

    fetch('/pedido', {
      method:      'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type':  'application/json',
        'X-CSRF-Token':  csrfToken
      },
      body: JSON.stringify({ items: items, notes: '' })
    })
    .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data: data }; }); })
    .then(function(result) {
      if (result.ok && result.data.order_id) {
        showToast('Pedido #' + result.data.order_id + ' salvo com sucesso');
      }
    })
    .catch(function() {})
    .finally(function() {
      window.open(waUrl, '_blank', 'noopener');
    });
  };

  btn.href = waUrl;
  btn.style.display = 'block';
}

function showToast(message) {
  var toast = document.createElement('div');
  toast.textContent = message;
  toast.style.cssText = [
    'position:fixed', 'bottom:24px', 'left:50%', 'transform:translateX(-50%)',
    'background:var(--brand-foreground)', 'color:#fff',
    'padding:12px 24px', 'font-family:var(--font-mono)', 'font-size:13px',
    'letter-spacing:0.05em', 'z-index:9999', 'pointer-events:none',
    'opacity:1', 'transition:opacity 0.4s ease'
  ].join(';');
  document.body.appendChild(toast);
  setTimeout(function() {
    toast.style.opacity = '0';
    setTimeout(function() { toast.remove(); }, 450);
  }, 3000);
}

function filterCol(slug) {
  document.querySelectorAll('#col-filters button').forEach(function(b) {
    var active = b.dataset.col === slug;
    b.style.background  = active ? 'var(--brand-foreground)' : '#fff';
    b.style.color       = active ? '#fff' : 'var(--brand-foreground)';
    b.style.borderColor = active ? 'var(--brand-foreground)' : 'var(--brand-border)';
  });
  document.querySelectorAll('.product-grade').forEach(function(g) {
    g.style.display = (slug === 'all' || g.dataset.col === slug) ? 'block' : 'none';
  });
}

function brl(n) {
  return 'R$ ' + n.toFixed(2).replace('.', ',');
}
</script>

<style>
  input[type=number]::-webkit-inner-spin-button,
  input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }
</style>

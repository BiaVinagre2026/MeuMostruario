<% content_for :title, @look.name %>
<% content_for :description, @look.description %>

<div class="max-w-7xl mx-auto px-6 py-12">

  <div style="margin-bottom:48px;">
    <div style="font-size:10px;letter-spacing:0.14em;text-transform:uppercase;font-family:var(--font-mono);color:var(--brand-muted);margin-bottom:12px;">Look</div>
    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,6vw,4rem);font-weight:300;letter-spacing:-0.02em;line-height:1;margin-bottom:16px;"><%= @look.name %></h1>
    <% if @look.description.present? %>
      <p style="max-width:600px;font-size:15px;line-height:1.7;color:var(--brand-muted);"><%= @look.description %></p>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

    <%# Imagem do look %>
    <div style="aspect-ratio:3/4;background:var(--brand-surface);overflow:hidden;">
      <% if @look.cover_url.present? %>
        <img src="<%= @look.cover_url %>" alt="<%= @look.name %>" style="width:100%;height:100%;object-fit:cover;" />
      <% end %>
    </div>

    <%# Peças %>
    <div>
      <div style="font-size:10px;letter-spacing:0.14em;text-transform:uppercase;font-family:var(--font-mono);color:var(--brand-muted);margin-bottom:24px;">
        Peças deste look (<%= @look.products.size %>)
      </div>
      <% @look.products.each do |p| %>
        <%= link_to public_product_path(p.slug),
              style: "display:flex;gap:16px;align-items:center;padding:16px 0;border-bottom:1px solid var(--brand-border);text-decoration:none;color:inherit;" do %>
          <div style="width:72px;height:96px;flex-shrink:0;background:var(--brand-surface);overflow:hidden;">
            <% if (img = cover_url(p)) %>
              <img src="<%= img %>" alt="<%= p.name %>" style="width:100%;height:100%;object-fit:cover;" loading="lazy" />
            <% end %>
          </div>
          <div style="flex:1;">
            <div style="font-size:14px;font-weight:500;margin-bottom:4px;"><%= p.name %></div>
            <div style="font-family:var(--font-mono);font-size:11px;color:var(--brand-muted);margin-bottom:6px;">SKU <%= p.sku %></div>
            <div style="font-family:var(--font-mono);font-size:13px;font-weight:500;"><%= format_brl(p.price_wholesale) %></div>
          </div>
          <span style="font-size:18px;color:var(--brand-muted);">→</span>
        <% end %>
      <% end %>
    </div>

  </div>
</div>
